# =============================================================================
# MCP Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Only include the variables needed for your chosen auth module.

# --- Bearer Token Auth (auth/bearer.py) ---
# SERVICE_API_TOKEN=your_access_token_here

# --- API Key Auth (auth/api_key.py) ---
# SERVICE_API_KEY=your_api_key_here

# --- OAuth 2.0 Auth (auth/oauth2.py) ---
# SERVICE_CLIENT_ID=your_client_id
# SERVICE_CLIENT_SECRET=your_client_secret

# --- No Auth (auth/none.py) ---
# (no variables needed)
