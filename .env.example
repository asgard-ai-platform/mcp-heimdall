# =============================================================================
# MCP Heimdall — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# Bearer token for Heimdall API (required)
HEIMDALL_API_TOKEN=your_access_token_here

# API base URL (optional override; omit to use the default production API)
HEIMDALL_API_BASE_URL=https://heimdall-api.asgard-ai.com
